# Markdown / prompts / notes (code-only pushes)
*.md
**/*.md

# Root README (GitHub repository front page)
!README.md

# StanfordScreenomics/doc — entire tree trackable (overrides *.md / **/*.md above; this path only)
!StanfordScreenomics/doc/
!StanfordScreenomics/doc/**

# Top-level doc/ (paper, spec, cross-reference markdown)
!doc/
!doc/**/*.md

# Firebase & local secrets
google-services.json
**/google-services.json
secrets.properties
**/secrets.properties

# Cursor / IDE (if present under repo)
.cursor/
**/.cursor/
.cursorrules
.cursorignore
**/.cursorrules
**/.cursorignore

# Kotlin build cache (module-local)
StanfordScreenomics/.kotlin/

# Logs & crash dumps
*.log
hs_err_pid*.log
replay_pid*.log

# macOS
.DS_Store
